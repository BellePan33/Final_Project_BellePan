<div class="container py-5">
  <h1>Book a Makeup Artist: {{artist.name}}</h1>
  <form action="/bookings" method="POST">
    <input type="hidden" name="artistId" value="{{artist._id}}">
    
    <div class="mb-3">
      <label class="form-label">Cosplayer Name:</label>
      <input type="text" name="clientName" class="form-control" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Character:</label>
      <input type="text" name="cosplayCharacter" class="form-control" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Select Time Range</label>
      <select name="slot" class="form-select">
        {{#each artist.availableSlots}}
          <option value="{{this}}">{{this}}</option>
        {{/each}}
      </select>
    </div>

    <button type="submit" class="btn btn-success">Confirm Appointment</button>
  </form>
</div>