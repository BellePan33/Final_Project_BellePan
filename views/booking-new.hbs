<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Book a Makeup Artist</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
</head>
<body class="bg-light">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8 col-xl-6">
        <div class="card shadow-sm">
          <div class="card-body p-4">
            <h1 class="h2 mb-4 text-center">Book a Makeup Artist: {{artist.name}}</h1>

            <form action="/bookings" method="POST">
              <input type="hidden" name="artistId" value="{{artist._id}}">

              <div class="mb-3">
                <label for="clientName" class="form-label">Cosplayer Name</label>
                <input
                  type="text"
                  id="clientName"
                  name="clientName"
                  class="form-control"
                  required
                >
              </div>

              <div class="mb-3">
                <label for="cosplayCharacter" class="form-label">Character</label>
                <input
                  type="text"
                  id="cosplayCharacter"
                  name="cosplayCharacter"
                  class="form-control"
                  required
                >
              </div>

              <div class="mb-3">
                <label for="slot" class="form-label">Select Time Range</label>
                <select id="slot" name="slot" class="form-select" required>
                  <option value="">Choose a time slot</option>
                  <option value="5:00 AM - 5:40 AM">5:00 AM - 5:40 AM</option>
                  <option value="5:40 AM - 6:20 AM">5:40 AM - 6:20 AM</option>
                  <option value="6:20 AM - 7:00 AM">6:20 AM - 7:00 AM</option>
                  <option value="7:00 AM - 7:40 AM">7:00 AM - 7:40 AM</option>
                </select>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Confirm Appointment</button>
                <a href="/artists" class="btn btn-outline-secondary">Back to Artists</a>
              </div>
            </form>

          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>