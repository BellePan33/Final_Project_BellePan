<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cosplay Makeup Booking App</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
</head>
<body class="bg-light">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card shadow-sm">
          <div class="card-body p-5 text-center">
            <h1 class="display-5 fw-bold mb-3">Cosplay Makeup Booking App</h1>
            <p class="lead mb-4">
              Choose your role to continue.
            </p>

            <div class="d-grid gap-3 col-md-8 mx-auto">
              <a href="/artists/portal" class="btn btn-primary btn-lg">
                I am a Makeup Artist
              </a>
              <a href="/customers/start" class="btn btn-outline-secondary btn-lg">
                I am a Cosplayer
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>