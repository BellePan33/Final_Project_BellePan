<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cosplay Makeup Booking Web</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
</head>
<body class="bg-light">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card shadow-sm">
          <div class="card-body p-5 text-center">
            <h1 class="display-5 fw-bold mb-3">Cosplay Makeup Booking Website</h1>
            <p class="lead mb-4">
              A web app for cosplay makeup artists and cosplayers to make convention booking
              easier, clearer, and more organized.
            </p>

            <div class="d-grid gap-2 d-md-flex justify-content-md-center">
              <a href="/artists/new" class="btn btn-primary btn-lg">
                Create Artist Profile
              </a>
              <a href="/artists" class="btn btn-outline-secondary btn-lg">
                Browse Artists
              </a>
            </div>

            <hr class="my-5">

            <div class="row text-start">
              <div class="col-md-6 mb-3">
                <h2 class="h5">For Makeup Artists</h2>
                <p class="mb-0">
                  Create a profile with your city, convention, specialty, and contact information.
                </p>
              </div>
              <div class="col-md-6 mb-3">
                <h2 class="h5">For Cosplayers</h2>
                <p class="mb-0">
                  Browse artist profiles and find the right makeup artist for your convention.
                </p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>