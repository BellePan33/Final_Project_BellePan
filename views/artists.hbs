<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Artist List</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
</head>
<body class="bg-light">
  <div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0">Artist List</h1>
      <a href="/artists/new" class="btn btn-primary">Create New Artist Profile</a>
    </div>

    {{#if artists.length}}
      <div class="row g-3">
        {{#each artists}}
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <h2 class="h5 card-title">{{this.name}}</h2>
                <p class="card-text mb-1"><strong>City:</strong> {{this.city}}</p>
                <p class="card-text mb-1"><strong>Convention:</strong> {{this.convention}}</p>
                <p class="card-text mb-1"><strong>Specialty:</strong> {{this.specialty}}</p>
                <p class="card-text"><strong>Contact:</strong> {{this.contact}}</p>
                <p class="card-text">
                  <small class="text-muted">Joined: {{this.formattedDate}}</small>
                </p>

                <a href="/bookings/new/{{this._id}}?customerName={{../customerName}}" class="btn btn-outline-primary">
                  Book This Artist
                </a>
              </div>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="alert alert-secondary">
        No artists yet.
      </div>
    {{/if}}
  </div>
</body>
</html>